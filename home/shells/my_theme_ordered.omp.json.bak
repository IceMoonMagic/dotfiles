{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "palettes": {
        "template": "{{ if eq .Env.TermColorTheme \"latte\" }}latte{{ else }}{{ if eq .Env.TermColorTheme \"frappe\" }}frappe{{ else }}{{ if eq .Env.TermColorTheme \"macchiato\" }}macchiato{{ else }}mocha{{ end }}{{ end }}{{ end }}",
        "list": {
            "latte": {
                "rosewater": "#dc8a78",
                "flamingo": "#dd7878",
                "pink": "#ea76cb",
                "mauve": "#8839ef",
                "red": "#d20f39",
                "maroon": "#e64553",
                "peach": "#fe640b",
                "yellow": "#df8e1d",
                "green": "#40a02b",
                "teal": "#179299",
                "sky": "#04a5e5",
                "sapphire": "#209fb5",
                "blue": "#1e66f5",
                "lavender": "#7287fd",
                "text": "#4c4f69",
                "subtext": "#6c6f85",
                "overlay": "#9ca0b0",
                "surface": "#ccd0da",
                "crust": "#dce0e8"
            },
            "frappe": {
                "rosewater": "#f2d5cf",
                "flamingo": "#eebebe",
                "pink": "#f4b8e4",
                "mauve": "#ca9ee6",
                "red": "#e78284",
                "maroon": "#ea999c",
                "peach": "#ef9f76",
                "yellow": "#e5c890",
                "green": "#a6d189",
                "teal": "#81c8be",
                "sky": "#99d1db",
                "sapphire": "#85c1dc",
                "blue": "#8caaee",
                "lavender": "#babbf1",
                "text": "#c6d0f5",
                "subtext": "#a5adce",
                "overlay": "#737994",
                "surface": "#414559",
                "crust": "#232634"
            },
            "macchiato": {
                "rosewater": "#f4dbd6",
                "flamingo": "#f0c6c6",
                "pink": "#f5bde6",
                "mauve": "#c6a0f6",
                "red": "#ed8796",
                "maroon": "#ee99a0",
                "peach": "#f5a97f",
                "yellow": "#eed49f",
                "green": "#a6da95",
                "teal": "#8bd5ca",
                "sky": "#91d7e3",
                "sapphire": "#7dc4e4",
                "blue": "#8aadf4",
                "lavender": "#b7bdf8",
                "text": "#cad3f5",
                "subtext": "#a5adcb",
                "overlay": "#6e738d",
                "surface": "#363a4f",
                "crust": "#181926"
            },
            "mocha": {
                "rosewater": "#f5e0dc",
                "flamingo": "#f2cdcd",
                "pink": "#f5c2e7",
                "mauve": "#cba6f7",
                "red": "#f38ba8",
                "maroon": "#eba0ac",
                "peach": "#fab387",
                "yellow": "#f9e2af",
                "green": "#a6e3a1",
                "teal": "#94e2d5",
                "sky": "#89dceb",
                "sapphire": "#74c7ec",
                "blue": "#89b4fa",
                "lavender": "#b4befe",
                "text": "#cdd6f4",
                "subtext": "#a6adc8",
                "overlay": "#6c7086",
                "surface": "#313244",
                "crust": "#11111b"
            }
        }
    },
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "segments": [
                {
                    "type": "exit",
                    "style": "diamond",
                    "leading_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:red",
                    "background_templates": [
                        "{{ if eq .Code 0 }}p:green{{ else if eq .Meaning \"SIGINT\" }}p:subtext{{end}}"
                    ],
                    "template": "{{ if eq .Code 0 }}{{ else if eq .Meaning \"SIGINT\" }}{{ else }} {{ .Code }}{{ end }} ",
                    "properties": {
                        "always_enabled": true
                    }
                },
                {
                    "type": "executiontime",
                    "style": "diamond",
                    "trailing_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:subtext",
                    "template": "  {{ .FormattedMs }}",
                    "properties": {
                        "style": "roundrock",
                        "threshold": 0
                    }
                },
                {
                    "type": "nix-shell",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:peach",
                    "template": " {{ .Type }}"
                },
                {
                    "type": "git",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:peach",
                    "template": "{{ .UpstreamIcon }}{{ .RepoName }} {{ .HEAD }}",
                    "properties": {
                        "branch_icon": " ",
                        "git_icon": " ",
                        "fetch_upstream_icon": true
                    }
                },
                {
                    "type": "python",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:yellow",
                    "templates": [
                        " ",
                        "{{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}",
                        "{{ if .Venv }} ({{ .Venv }}){{ end }}"
                    ],
                    "properties": {
                        "display_mode": "context"
                    }
                },
                {
                    "type": "node",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:green",
                    "template": "{{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}",
                    "properties": {
                        "fetch_package_manager": true,
                        "npm_icon": "",
                        "yarn_icon": "󰄛"
                    }
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:rosewater",
                    "template": "╭─"
                },
                {
                    "type": "os",
                    "style": "diamond",
                    "powerline_symbol": "",
                    "leading_diamond": "",
                    "foreground": "p:crust",
                    "background": "p:teal",
                    "template": "{{ .Icon }} "
                },
                {
                    "type": "session",
                    "style": "diamond",
                    "powerline_symbol": "",
                    "foreground": "p:crust",
                    "background": "p:teal",
                    "templates": [
                        "{{ if .SSHSession }}󰢩 {{ end }}",
                        "{{ if .Root }}󰀅 {{ end }}",
                        "{{ .UserName }}@{{ .HostName }}"
                    ]
                },
                {
                    "type": "path",
                    "style": "powerline",
                    "powerline_symbol": "",
                    "foreground": "p:crust",
                    "background": "p:mauve",
                    "template": " {{ if not .Writable }}󰷤 {{ end }}{{ .Path }}",
                    "properties": {
                        "folder_icon": "  ",
                        "home_icon": " ",
                        "style": "agnoster",
                        "mixed_threshold": 10,
                        "mapped_locations": {
                            "~/Desktop": "󰍹 ",
                            "~/Documents": " ",
                            "~/Downloads": "󰇚 ",
                            "/tmp": " ",
                            "/mnt": " ",
                            "/run/media/roboticat/": "󱊞 "
                        }
                    }
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:rosewater",
                    "template": "╰─❯"
                }
            ]
        }
    ],
    "final_space": true,
    "version": 2
}
